+findbar-case-sensitive =
+    .label = Diferenciar maiĂșsculas/minĂșsculas
+    .accesskey = m
+    .tooltiptext = Procurar considerando diferenĂ§as entre maiĂșsculas e minĂșsculas
+findbar-match-diacritics =
+    .label = Considerar acentuaĂ§ĂŁo
+    .accesskey = C
+    .tooltiptext = Distinguir letras acentuadas de suas letras de base (por exemplo, ao procurar âParĂĄâ, nĂŁo serĂŁo consideradas as ocorrĂȘncias de âparaâ)
+findbar-entire-word =
