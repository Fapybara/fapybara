+
+# Header of the Protections Panel.
+protections-header = ProteĂ§Ă”es em { $host }
+
+## Blocking and Not Blocking sub-views in the Protections Panel
+
+protections-blocking-fingerprinters =
+    .title = Fingerprinters bloqueados
